{
  "enabled": true,
  "name": "Build Validation",
  "description": "Runs dotnet build on the affected project after code changes to catch compile errors immediately.",
  "version": "2",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.cs",
      "*.csproj"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A .cs or .csproj file was modified. Determine which project it belongs to based on the file path, then run the appropriate build command:\n\n- verification/: `dotnet build src/Verification.sln` (from verification/)\n- identification/: `dotnet build src/Identification.sln` (from identification/)\n- kyc-customer-due-diligence/: `dotnet build src/CustomerDueDiligence.sln` (from kyc-customer-due-diligence/)\n- cdd-business/: `dotnet build src/KYC.CDD.sln` (from cdd-business/)\n- kyc-e-kyc-api/: `dotnet build src/2C2P.eKYC.sln` (from kyc-e-kyc-api/)\n- kyc-partner-api/: `dotnet build DipChip.sln` (from kyc-partner-api/)\n- kyc-admin-portal/: `dotnet build eKycApp/eKycApp.sln` (from kyc-admin-portal/)\n\nIf the build fails, show the error and attempt to fix it. Do not proceed until the build succeeds."
  },
  "shortName": "build-validation"
}
