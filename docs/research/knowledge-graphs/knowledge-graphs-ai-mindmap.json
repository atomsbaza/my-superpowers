    {
      "name": "KGs as Agent Memory",
      "children": [
        {
          "name": "Temporal / Bi-Temporal Model",
          "children": [
            {
              "name": "t_valid / t_invalid: when a fact was true in the world"
            },
            {
              "name": "t_created / t_expired: when the system learned about it"
            },
            {
              "name": "Resolves contradictions without overwriting earlier facts"
            }
          ]
        },
        {
          "name": "Episodic vs. Semantic Memory",
          "children": [
            {
              "name": "Episodic buffer: last ~10 raw conversation turns"
            },
            {
              "name": "Semantic (neocortical) memory: consolidates slowly, ~3 tokens/message growth"
            },
            {
              "name": "Mirrors complementary-learning-systems theory from cognitive science"
            }
          ]
        },
        {
          "name": "Consolidation Pipeline",
          "children": [
            {
              "name": "Stage 1: LLM extraction plus contradiction detection"
            },
            {
              "name": "Stage 2: conflict resolution via temporal precedence"
            },
            {
              "name": "Stage 3: incremental entity/user profile update, not full rebuild"
            }
          ]
        },
        {
          "name": "Entity Resolution",
          "children": [
            {
              "name": "Multi-layer matching: embedding similarity, fuzzy strings, type constraints"
            },
            {
              "name": "Mid-confidence matches create a SAME_AS edge flagged for human review"
            },
            {
              "name": "Avoids silent identity-merging errors"
            }
          ]
        },
        {
          "name": "Forgetting",
          "children": [
            {
              "name": "Pruning and selective retention"
            },
            {
              "name": "Mitigation of catastrophic forgetting"
            },
            {
              "name": "'Forgetting-by-design' as a resource-optimization technique, not a failure mode"
            }
          ]
        },
        {
          "name": "Benchmarks",
          "children": [
            {
              "name": "Zep DMR: 94.8% vs. MemGPT 93.4%"
            },
            {
              "name": "LongMemEval: Zep 63.8% vs. Mem0 (vector) 49.0%"
            },
            {
              "name": "Context reduction: ~115k tokens down to ~1.6k"
