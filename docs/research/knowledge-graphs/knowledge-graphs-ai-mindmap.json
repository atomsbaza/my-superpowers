        {
          "name": "Caveats",
          "children": [
            {
              "name": "Kuzu's archival makes it a poor new choice regardless of technical merit"
            },
            {
              "name": "Memgraph licensing needs legal review before commercial use"
            },
            {
              "name": "GraphRAG vs. LightRAG is a workload trade-off, not a strict upgrade path"
