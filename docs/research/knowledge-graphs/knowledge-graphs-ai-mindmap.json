    },
    {
      "name": "Decision Guide",
      "children": [
        {
          "name": "Single-hop facts, cost-sensitive, high volume \u2192 Dense RAG with strong (32B+) LLM"
        },
        {
          "name": "Multi-hop or entity-dense domains (medical, legal) \u2192 GraphRAG (e.g. HippoRAG2)"
        },
        {
          "name": "Specialized domain schemas, need logic-level accuracy \u2192 KAG (Knowledge-Augmented Generation)"
        },
        {
          "name": "High-stakes / regulated tasks (healthcare, finance, law) \u2192 Neuro-Symbolic verifiers"
        },
        {
          "name": "Task requires decomposition into sub-goals \u2192 training-free agentic workflow (GraphSearch style)"
        },
        {
          "name": "Training a custom search agent \u2192 GRPO as the favorable optimization paradigm"
        },
        {
          "name": "Conversational agent memory with evolving facts \u2192 temporal KG (Graphiti/Zep) over vector-only memory"
        }
      ]
    }
